+'use client';
+
+import { useState } from 'react';
+
+type Receipt = {
+  ok?: boolean;
+  receiptId?: string;
+  label?: string;
+  nextStep?: string;
+  error?: string;
+};
+
+const actions = [
+  { action: 'approve_scope', label: 'Aprovar escopo P2', note: 'Lucas aprovou desbloquear itens 10, 11 e 12 no Mission Control.' },
+  { action: 'preview_only', label: 'Preview only', note: 'Manter pacote sem execução operacional.' },
+  { action: 'adjust', label: 'Ajustar', note: 'Precisa ajuste antes da execução.' },
+  { action: 'block', label: 'Bloquear', note: 'Bloqueado por Lucas.' },
+];
+
+export function CommandActionPanel() {
+  const [receipt, setReceipt] = useState<Receipt | null>(null);
+  const [loading, setLoading] = useState<string | null>(null);
+
+  async function send(action: string, note: string) {
+    setLoading(action);
+    setReceipt(null);
+    try {
+      const response = await fetch('/api/mission/approvals', {
+        method: 'POST',
+        headers: { 'content-type': 'application/json' },
+        body: JSON.stringify({
+          packetId: 'mission-control-p2-backend-api-kanban',
+          action,
+          note,
+          source: 'mission-control-command-panel',
+        }),
+      });
+      const data = await response.json();
+      setReceipt(data);
+    } catch {
+      setReceipt({ ok: false, error: 'request_failed' });
+    } finally {
+      setLoading(null);
+    }
+  }
+
+  async function kanbanPacket() {
+    setLoading('kanban_dispatch_packet');
+    setReceipt(null);
+    try {
+      const response = await fetch('/api/mission/kanban', {
+        method: 'POST',
+        headers: { 'content-type': 'application/json' },
+        body: JSON.stringify({
+          packetId: 'lk-growth-ops-dispatch-pilot',
+          action: 'kanban_dispatch_packet',
+          note: 'Gerar pacote de despacho restrito para workers read-only do board lk-growth-ops.',
+          source: 'mission-control-command-panel',
+        }),
+      });
+      const data = await response.json();
+      setReceipt(data);
+    } catch {
+      setReceipt({ ok: false, error: 'request_failed' });
+    } finally {
+      setLoading(null);
+    }
+  }
+
+  return <div className="command-actions" aria-label="Mission Control backend actions">
+    <div className="command-action-buttons">
+      {actions.map((item) => <button key={item.action} type="button" onClick={() => send(item.action, item.note)} disabled={loading !== null}>
+        {loading === item.action ? 'Registrando…' : item.label}
+      </button>)}
+      <button type="button" onClick={kanbanPacket} disabled={loading !== null}>
+        {loading === 'kanban_dispatch_packet' ? 'Gerando…' : 'Kanban packet'}
+      </button>
+    </div>
+    <p>Backend real ativo: valida allowlist, redige payload, emite recibo e não executa ação externa, segredo, Docker, Shopify/Tiny/Merchant ou comando arbitrário pelo browser.</p>
