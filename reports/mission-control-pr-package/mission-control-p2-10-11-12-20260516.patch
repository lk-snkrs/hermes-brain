+  return input
+    .normalize('NFKD')
+    .replace(/[\u0300-\u036f]/g, '')
+    .toLowerCase()
+    .replace(/[^a-z0-9]+/g, '-')
+    .replace(/^-+|-+$/g, '')
+    .slice(0, 96);
+}
+
+export function publicHeaders() {
+  return {
+    'cache-control': 'no-store, max-age=0',
+    'content-type': 'application/json; charset=utf-8',
+    'x-mission-control': 'lucas-command-system',
+    'x-robots-tag': 'noindex',
+  };
+}
+
+export function sanitizeText(value: unknown, max = 600) {
+  const text = typeof value === 'string' ? value : '';
+  return text
+    .replace(/(sk-|ghp_|gho_|xox[baprs]-|AIza|ya29\.|-----BEGIN [A-Z ]+PRIVATE KEY-----)[A-Za-z0-9_./+=:-]*/g, '[REDACTED]')
+    .replace(/[A-Za-z0-9._%+-]+@[A-Za-z0-9.-]+\.[A-Za-z]{2,}/g, '[email-redacted]')
+    .replace(/\s+/g, ' ')
+    .trim()
+    .slice(0, max);
+}
+
+export function parseAction(value: unknown): MissionAction | null {
+  if (value === 'approve_scope' || value === 'adjust' || value === 'preview_only' || value === 'block' || value === 'kanban_dispatch_packet') return value;
+  return null;
+}
+
+export function makeApprovalReceipt(input: {
+  packetId: string;
+  action: MissionAction;
+  note?: string;
+  source?: string;
+}) {
+  const packetId = slugify(input.packetId || 'mission-control-p2-backend-api-kanban');
+  const action = input.action;
+  if (!ALLOWED_PACKET_IDS.has(packetId)) {
+    throw new Error('packet_id_not_allowlisted');
+  }
+  const note = sanitizeText(input.note || '', 420);
+  const receivedAt = new Date().toISOString();
+  const scope = {
+    gate: action === 'approve_scope' || action === 'kanban_dispatch_packet' ? 'A3' : 'A2',
+    execution: action === 'approve_scope' ? 'accepted-for-human-reviewed-ops-queue' : 'no-mutating-execution',
+    externalSend: false,
+    secrets: false,
+    rollback: 'disable API routes and redeploy previous Vercel build; no external data was mutated by this receipt endpoint',
+  };
+  const receiptBase = JSON.stringify({ packetId, action, note, receivedAt, scope });
+  const receiptId = createHash('sha256').update(receiptBase).digest('hex').slice(0, 16);
+  return {
+    ok: true,
+    receiptId,
+    packetId,
+    action,
+    label: ACTION_LABELS[action],
+    note,
+    receivedAt,
+    source: sanitizeText(input.source || 'mission-control-ui', 120),
+    scope,
+    nextStep: action === 'approve_scope'
+      ? 'Escopo aprovado por Lucas; execução operacional ainda passa pelos guardrails do pacote e logs locais.'
+      : 'Nenhuma mutação executada; o retorno serve como trilha de decisão e instrução de próximo passo.',
+  };
+}
+
+export function kanbanCapabilities() {
+  return {
+    ok: true,
+    board: 'lk-growth-ops',
+    mode: 'restricted-workers',
+    publicEndpointExecutesWorkers: false,
+    profiles: KANBAN_PROFILES.map((profile) => ({
+      profile,
+      permission: profile.includes('readonly') ? 'read-only/local' : 'local-brain-only',
+      allowedActions: ['read Brain context', 'summarize', 'draft local report', 'block for Lucas when A3/A4 is needed'],
+      deniedActions: ['external send', 'Shopify/Tiny/Merchant write', 'Docker/host mutation', 'secret print', 'destructive command'],
+    })),
+    lanes: ['Backlog', 'Ready', 'Doing', 'Waiting Lucas', 'Waiting External', 'QA', 'Done'],
+    dispatchContract: 'Gateway/local Hermes dispatcher only; public API creates/validates packets and never spawns arbitrary code from the browser.',
+    rollback: 'unassign ready worker cards or disable dispatch cron/gateway integration; API route can be removed and previous Vercel deploy promoted.',
+  };
+}
