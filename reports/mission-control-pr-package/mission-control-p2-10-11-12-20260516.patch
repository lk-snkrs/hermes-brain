+import { NextRequest } from 'next/server';
+import { kanbanCapabilities, makeApprovalReceipt, parseAction, publicHeaders, sanitizeText } from '@/lib/mission-control-api';
+
+export const dynamic = 'force-dynamic';
+
+export async function GET() {
+  return Response.json(kanbanCapabilities(), { headers: publicHeaders() });
+}
+
+export async function POST(request: NextRequest) {
+  const body = await request.json().catch(() => ({}));
+  const action = parseAction(body.action || 'kanban_dispatch_packet');
+  if (action !== 'kanban_dispatch_packet') {
+    return Response.json({ ok: false, error: 'kanban_endpoint_only_accepts_dispatch_packets' }, { status: 400, headers: publicHeaders() });
+  }
+  try {
+    const receipt = makeApprovalReceipt({
+      packetId: body.packetId || 'lk-growth-ops-dispatch-pilot',
+      action,
+      note: sanitizeText(body.note || 'restricted read-only worker dispatch packet requested', 420),
+      source: sanitizeText(body.source || 'mission-control-kanban-api', 120),
+    });
+    return Response.json({
+      ...receipt,
+      kanban: kanbanCapabilities(),
+      executionBoundary: 'Browser/API does not spawn code. Approved packets are consumed by local Hermes/gateway operators with restricted profiles.',
+    }, { headers: publicHeaders() });
+  } catch (error) {
+    const message = error instanceof Error ? error.message : 'unknown_error';
+    return Response.json({ ok: false, error: message }, { status: 400, headers: publicHeaders() });
+  }
+}
