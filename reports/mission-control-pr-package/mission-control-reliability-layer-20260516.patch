index 0000000..d7a63f0
--- /dev/null
+++ b/src/components/modules/CommandActionPanel.tsx
@@ -0,0 +1,78 @@
+'use client';
+
+import { useState } from 'react';
+
+type Receipt = {
+  ok?: boolean;
+  receiptId?: string;
+  label?: string;
+  nextStep?: string;
+  packet?: { decision?: string; company?: string; safeAction?: string } | null;
+  scope?: { expiresAt?: string | null; payloadHash?: string; gate?: string };
+  error?: string;
+};
+
+const actions = [
+  { action: 'approve_scope', label: 'Aprovar escopo', note: 'Lucas aprovou o pacote apresentado no Mission Control.' },
+  { action: 'preview_only', label: 'Preview only', note: 'Manter pacote sem execução operacional.' },
+  { action: 'adjust', label: 'Ajustar', note: 'Precisa ajuste antes da execução.' },
+  { action: 'block', label: 'Bloquear', note: 'Bloqueado por Lucas.' },
+];
+
+const packets = [
+  { id: 'mission-control-reliability-layer', label: 'Reliability Layer' },
+  { id: 'lk-operating-intelligence-readonly', label: 'LK Intelligence' },
+  { id: 'kanban-restricted-dispatch-policy', label: 'Kanban Policy' },
+];
+
+export function CommandActionPanel() {
+  const [receipt, setReceipt] = useState<Receipt | null>(null);
+  const [loading, setLoading] = useState<string | null>(null);
+  const [packetId, setPacketId] = useState(packets[0].id);
+
+  async function send(action: string, note: string, endpoint = '/api/mission/approvals') {
+    setLoading(action);
+    setReceipt(null);
+    try {
+      const response = await fetch(endpoint, {
+        method: 'POST',
+        headers: { 'content-type': 'application/json' },
+        body: JSON.stringify({
+          packetId,
+          action,
+          note,
+          source: 'mission-control-command-panel',
+        }),
+      });
+      const data = await response.json();
+      setReceipt(data);
+    } catch {
+      setReceipt({ ok: false, error: 'request_failed' });
+    } finally {
+      setLoading(null);
+    }
+  }
+
+  async function kanbanPacket() {
+    const previous = packetId;
+    setPacketId('kanban-restricted-dispatch-policy');
+    await send('kanban_dispatch_packet', 'Gerar pacote de despacho restrito por lane para workers read-only do board lk-growth-ops.', '/api/mission/kanban');
+    setPacketId(previous);
+  }
+
+  return <div className="command-actions" aria-label="Mission Control backend actions">
+    <label className="command-packet-picker"><span>Packet</span><select value={packetId} onChange={(event) => setPacketId(event.target.value)}>{packets.map((packet) => <option key={packet.id} value={packet.id}>{packet.label}</option>)}</select></label>
+    <div className="command-action-buttons">
+      {actions.map((item) => <button key={item.action} type="button" onClick={() => send(item.action, item.note)} disabled={loading !== null}>
+        {loading === item.action ? 'Registrando…' : item.label}
+      </button>)}
+      <button type="button" onClick={kanbanPacket} disabled={loading !== null}>
+        {loading === 'kanban_dispatch_packet' ? 'Gerando…' : 'Kanban packet'}
+      </button>
+    </div>
+    <p>Backend real ativo: valida allowlist, expiração, rate-limit, token opcional, redige payload, emite recibo e não executa ação externa, segredo, Docker, Shopify/Tiny/Merchant ou comando arbitrário pelo browser.</p>
+    {receipt && <output className={receipt.ok ? 'command-receipt' : 'command-receipt error'}>
+      {receipt.ok ? <><b>Receipt {receipt.receiptId}</b><span>{receipt.packet?.company} · {receipt.packet?.decision || receipt.label}</span><small>{receipt.scope?.gate} · hash {receipt.scope?.payloadHash} · expira {receipt.scope?.expiresAt || 'n/a'}</small><small>{receipt.nextStep}</small></> : <><b>Erro</b><span>{receipt.error}</span></>}
+    </output>}
+  </div>;
+}
