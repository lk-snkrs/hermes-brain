+import { NextRequest } from 'next/server';
+import { checkRateLimit, kanbanCapabilities, makeApprovalReceipt, parseAction, publicHeaders, sanitizeText, verifyOptionalToken } from '@/lib/mission-control-api';
+
+export const dynamic = 'force-dynamic';
+
+type ApprovalBody = {
+  packetId?: string;
+  action?: string;
+  note?: string;
+  source?: string;
+};
+
+async function readBody(request: NextRequest): Promise<ApprovalBody> {
+  const contentType = request.headers.get('content-type') || '';
+  if (contentType.includes('application/json')) {
+    return await request.json().catch(() => ({}));
+  }
+  if (contentType.includes('application/x-www-form-urlencoded') || contentType.includes('multipart/form-data')) {
+    const form = await request.formData();
+    return {
+      packetId: String(form.get('packetId') || ''),
+      action: String(form.get('action') || ''),
+      note: String(form.get('note') || ''),
+      source: String(form.get('source') || ''),
+    };
+  }
+  return {};
+}
+
+function clientKey(request: NextRequest) {
+  return request.headers.get('x-forwarded-for')?.split(',')[0]?.trim() || request.headers.get('x-real-ip') || 'unknown-client';
+}
+
+export async function GET() {
+  return Response.json({
+    ok: true,
+    endpoint: '/api/mission/approvals',
+    status: 'active-hardened',
+    allowedActions: ['approve_scope', 'adjust', 'preview_only', 'block', 'kanban_dispatch_packet'],
+    guardrails: {
+      validatesAllowlist: true,
+      validatesExpiration: true,
+      redactsSecrets: true,
+      rateLimit: '30/minute per client key in function memory',
+      optionalAuth: 'MISSION_CONTROL_APPROVAL_TOKEN_HASH enables Bearer token sha256 check when configured',
+      executesExternalSend: false,
+      executesDockerOrHost: false,
+      executesShopifyTinyMerchantWrite: false,
+      persistence: 'receipt response + sanitized server log + Brain event ledger generated from approved packets; source-of-truth writes stay behind Hermes/operator gate',
+    },
+    kanban: kanbanCapabilities(),
+  }, { headers: publicHeaders() });
+}
+
+export async function POST(request: NextRequest) {
+  try {
+    const rate = checkRateLimit(clientKey(request));
+    if (!rate.ok) {
+      return Response.json({ ok: false, error: 'rate_limited', resetAt: new Date(rate.resetAt).toISOString() }, { status: 429, headers: publicHeaders({ 'x-ratelimit-remaining': '0' }) });
+    }
+    const auth = await verifyOptionalToken(request.headers.get('authorization'));
+    if (!auth.ok) {
+      return Response.json({ ok: false, error: 'unauthorized' }, { status: 401, headers: publicHeaders() });
+    }
+    const body = await readBody(request);
+    const action = parseAction(body.action);
+    if (!action) {
+      return Response.json({ ok: false, error: 'action_not_allowed' }, { status: 400, headers: publicHeaders() });
+    }
+    const receipt = makeApprovalReceipt({
+      packetId: body.packetId || 'mission-control-reliability-layer',
+      action,
+      note: sanitizeText(body.note || '', 420),
+      source: sanitizeText(body.source || 'mission-control-ui', 120),
+      clientKey: clientKey(request),
+    });
+    console.info('mission-control-approval-receipt', JSON.stringify({ ...receipt, note: sanitizeText(receipt.note, 120) }));
+    return Response.json({ ...receipt, authMode: auth.mode, rateLimitRemaining: rate.remaining }, { headers: publicHeaders({ 'x-ratelimit-remaining': String(rate.remaining) }) });
+  } catch (error) {
+    const message = error instanceof Error ? error.message : 'unknown_error';
+    return Response.json({ ok: false, error: message }, { status: 400, headers: publicHeaders() });
+  }
+}
