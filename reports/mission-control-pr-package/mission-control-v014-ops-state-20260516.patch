+#!/usr/bin/env python3
+"""Generate Mission Control operational state feed.
+
+Local/read-only inputs only. Writes sanitized JSON mirrors in the Brain and a generated
+TypeScript module for Mission Control. Does not touch Shopify/Tiny/Merchant, Docker,
+Vercel, GitHub, external messages, or secrets.
+"""
+from __future__ import annotations
+
+import datetime as dt
+import json
+import shutil
+from pathlib import Path
+
+ROOT = Path('/opt/data/hermes_bruno_ingest/mission-control-cimino-hermes')
+BRAIN = Path('/opt/data/hermes_bruno_ingest/hermes-brain')
+RUNTIME_SCRIPTS = Path('/opt/data/scripts')
+
+
+def utc_now() -> dt.datetime:
+    return dt.datetime.now(dt.UTC).replace(microsecond=0)
+
+
+def exists_status(path: Path, label: str) -> dict[str, str]:
+    if path.exists() and path.stat().st_size > 200:
+        return {'label': label, 'status': 'verified', 'detail': f'{path} existe ({path.stat().st_size} bytes)'}
+    if path.exists():
+        return {'label': label, 'status': 'attention', 'detail': f'{path} existe mas parece pequeno ({path.stat().st_size} bytes)'}
+    return {'label': label, 'status': 'missing', 'detail': f'{path} ausente'}
+
+
+def build_state() -> dict:
+    now = utc_now()
+    latest_json = BRAIN / 'reports/mission-control-ops-state-latest.json'
+    generated_ts = ROOT / 'src/data/ops-state.generated.ts'
+    mission_watchdog = RUNTIME_SCRIPTS / 'mission_control_ops_watchdog.py'
+    compression_watchdog = RUNTIME_SCRIPTS / 'hermes_compression_failure_self_heal.py'
+    shopify_skill = Path('/opt/data/skills/productivity/lk-shopify-readonly/SKILL.md')
+    product_upload_skill = Path('/opt/data/skills/productivity/lk-shopify-product-upload/SKILL.md')
+
+    return {
+        'generatedAt': now.isoformat().replace('+00:00', 'Z'),
+        'mode': 'read-only + approval-gated',
+        'freshnessSlaHours': 24,
+        'summary': 'Mission Control é a superfície central do Lucas OS: rituais Hermes v0.14, watchers silenciosos, Shopify skills verificadas, autocorreção de compressão e fila de aprovação estruturada.',
+        'health': [
+            exists_status(generated_ts, 'Mission Control generated feed'),
+            exists_status(latest_json, 'Brain JSON mirror'),
+            exists_status(mission_watchdog, 'Mission Control watchdog'),
+            exists_status(compression_watchdog, 'Compression self-heal watchdog'),
+            exists_status(shopify_skill, 'lk-shopify-readonly runtime skill'),
+            exists_status(product_upload_skill, 'lk-shopify-product-upload runtime skill'),
+        ],
+        'approvalLedger': [
+            {'gate':'A1','title':'Autonomia segura','scope':'Ler, resumir, comparar, gerar docs, QA, previews locais, watchdogs read-only/silent OK e autocorreções locais de baixo risco.', 'buttons':'executa sem pedir quando reversível'},
+            {'gate':'A2','title':'Preview / escopo aprovado','scope':'Mission Control, Brain, skills, relatórios, Vercel Mission Control com validação e rollback; outputs com payload inline.', 'buttons':'Aprovar escopo · Ajustar · Preview only'},
+            {'gate':'A3','title':'Fonte de verdade / infra','scope':'GitHub push/PR, Vercel config, banco, Docker, host, API/proxy, integrações críticas e gateway restart.', 'buttons':'pacote com rollback obrigatório'},
+            {'gate':'A4','title':'Externo / dinheiro / cliente','scope':'WhatsApp/email cliente, campanhas, compras, Shopify/Tiny/Merchant writes, secrets, destrutivo.', 'buttons':'aprovação atual e payload inline'},
+        ],
+        'waitingLucas': [
+            {'company':'Mission Control','decision':'Autorizar push/PR para transformar o pacote local validado em fonte Git formal.', 'recommendation':'Aprovar PR separado após diff/QA; não faço push automático.', 'gate':'A3'},
+            {'company':'LK Sneakers','decision':'Ativar inteligência Shopify read-only recorrente para divergências catálogo/CRM/stockout.', 'recommendation':'Começar read-only; achados viram preview/approval packet, sem write.', 'gate':'A2'},
+            {'company':'Hermes Runtime','decision':'Aplicar restart/redeploy para carregar patches de código do runtime Hermes quando houver mudança em módulo carregado.', 'recommendation':'Só com plano/rollback; watchdog de compressão já detecta e prepara correção, mas não reinicia gateway.', 'gate':'A3'},
+            {'company':'Zipper Galeria','decision':'Transformar follow-ups de feira em approval packets com texto inteiro no Telegram.', 'recommendation':'Draft-only; envio continua A4.', 'gate':'A4'},
+        ],
+        'watchers': [
+            {'id':'edd06fe19397','name':'Hermes runtime + cron','cadence':'*/30','contract':'silent OK'},
+            {'id':'feec299b99e5','name':'Mission Control ops','cadence':'*/15','contract':'silent OK · feed/freshness/skill drift/site'},
+            {'id':'4bb4e2223fd3','name':'Compression failure self-heal','cadence':'*/10','contract':'silent OK · autocorrige classificador/teste; sem restart'},
+            {'id':'051f05ce17c1','name':'Mordomo realtime','cadence':'*/15','contract':'actionable only'},
+            {'id':'f00c68f5967a','name':'Zipper daily cockpit','cadence':'08:15 BRT','contract':'mandatory summary'},
+            {'id':'af07bbc077b8','name':'Zipper inbox/followups','cadence':'*/30','contract':'silent OK'},
+            {'id':'7c688553e293','name':'LK daily sales brief','cadence':'08:00 BRT','contract':'mandatory summary'},
+        ],
+        'artifacts': [
+            {'path':'src/data/ops-state.generated.ts','kind':'Mission Control generated feed'},
+            {'path':'reports/mission-control-ops-state-latest.json','kind':'Brain JSON mirror'},
+            {'path':'scripts/mission_control_ops_state.py','kind':'repo generator source'},
+            {'path':'/opt/data/scripts/mission_control_ops_state.py','kind':'runtime generator'},
+            {'path':'/opt/data/scripts/mission_control_ops_watchdog.py','kind':'runtime silent watchdog'},
+        ],
+    }
+
+
+def write_state(state: dict) -> None:
+    reports = BRAIN / 'reports'
+    reports.mkdir(parents=True, exist_ok=True)
+    today = dt.datetime.now(dt.UTC).date().isoformat()
+    payload = json.dumps(state, ensure_ascii=False, indent=2)
+    (reports / 'mission-control-ops-state-latest.json').write_text(payload)
+    (reports / f'mission-control-ops-state-{today}.json').write_text(payload)
+
+    ts = "import type { PermissionLevel } from '@/lib/types';\n\n"
+    ts += 'export const opsState = ' + json.dumps(state, ensure_ascii=False, indent=2) + ' as const;\n\n'
+    ts += 'export type OpsApproval = { gate: PermissionLevel; title: string; scope: string; buttons: string };\n'
+    (ROOT / 'src/data/ops-state.generated.ts').write_text(ts)
+
+
+def main() -> int:
+    state = build_state()
+    write_state(state)
+    # Keep the runtime script and Brain script in sync when executed from repo copy.
+    this = Path(__file__).resolve()
+    for target in [RUNTIME_SCRIPTS / 'mission_control_ops_state.py', BRAIN / 'scripts/mission_control_ops_state.py']:
+        target.parent.mkdir(parents=True, exist_ok=True)
+        if this != target:
+            shutil.copy2(this, target)
+            target.chmod(0o700)
+    return 0
+
+
+if __name__ == '__main__':
+    raise SystemExit(main())
