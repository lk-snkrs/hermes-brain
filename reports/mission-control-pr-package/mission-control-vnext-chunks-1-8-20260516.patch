+def dedupe_by_key(items: Iterable[dict], key: str) -> tuple[list[dict], list[str]]:
+    """Keep the first occurrence of each key and report duplicates deterministically."""
+    seen: set[str] = set()
+    duplicates: list[str] = []
+    result: list[dict] = []
+    for raw in items:
