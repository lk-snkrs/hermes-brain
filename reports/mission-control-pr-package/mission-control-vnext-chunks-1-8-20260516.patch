+import json
+import subprocess
+import sys
+import unittest
+from pathlib import Path
+
+ROOT = Path(__file__).resolve().parents[1]
+QA_GATE = ROOT / 'scripts' / 'mission_control_qa_gate.py'
+
+
+class MissionControlQaGateTests(unittest.TestCase):
+    def test_package_json_exposes_single_local_qa_command(self):
+        package = json.loads((ROOT / 'package.json').read_text())
+
+        self.assertEqual(package['scripts']['qa:local'], 'python3 scripts/mission_control_qa_gate.py')
+
+    def test_qa_gate_plan_lists_required_checks_without_running_them(self):
+        proc = subprocess.run(
+            [sys.executable, str(QA_GATE), '--plan'],
+            cwd=ROOT,
+            text=True,
+            stdout=subprocess.PIPE,
+            stderr=subprocess.STDOUT,
+            timeout=15,
+        )
+
+        self.assertEqual(proc.returncode, 0, proc.stdout)
+        for marker in [
+            'python unittest watchdog fixtures',
+            'python py_compile watchdog scripts',
+            'mission watchdog silent OK',
+            'git diff whitespace check',
+            'git staged diff whitespace check',
+            'npm lint',
+            'npm build',
+            'diff secret scan',
+        ]:
+            self.assertIn(marker, proc.stdout)
+
+
+if __name__ == '__main__':
+    unittest.main()
