+#!/usr/bin/env python3
+"""Mission Control local QA gate.
+
+Runs read-only/local checks before Mission Control PR/deploy work. This script must not
+push, deploy, call Docker/VPS/gateway restarts, or mutate external systems.
+"""
+from __future__ import annotations
+
+import argparse
+import os
+import re
+import subprocess
+import sys
+from dataclasses import dataclass
+from pathlib import Path
+
+ROOT = Path(__file__).resolve().parents[1]
+RUNTIME_WATCHDOG = Path('/opt/data/scripts/mission_control_ops_watchdog.py')
+BRAIN_WATCHDOG = Path('/opt/data/hermes_bruno_ingest/hermes-brain/scripts/mission_control_ops_watchdog.py')
+REPO_WATCHDOG = ROOT / 'scripts' / 'mission_control_ops_watchdog.py'
+SECRET_RE = re.compile(
+    r'(api[_-]?key|secret|password|passwd|token)\s*[:=]\s*["\'][^"\']{6,}["\']|'
+    r'sk-[A-Za-z0-9]{16,}|ghp_[A-Za-z0-9]{16,}|xox[baprs]-[A-Za-z0-9-]{16,}',
+    re.IGNORECASE,
+)
+
+
+@dataclass(frozen=True)
+class Check:
+    name: str
+    command: list[str]
+    allow_stdout: bool = True
+
+
+CHECKS = [
+    Check('python unittest watchdog fixtures', [sys.executable, '-m', 'unittest', 'tests.test_mission_control_ops_watchdog', 'tests.test_mission_control_qa_gate', '-v']),
+    Check(
+        'python py_compile watchdog scripts',
+        [
+            sys.executable,
+            '-c',
+            "import py_compile, sys, tempfile; "
+            "[py_compile.compile(path, cfile=tempfile.NamedTemporaryFile(suffix='.pyc').name, doraise=True) for path in sys.argv[1:]]",
+            str(REPO_WATCHDOG),
+            str(RUNTIME_WATCHDOG),
+            str(BRAIN_WATCHDOG),
+        ],
+    ),
+    Check('mission watchdog silent OK', [str(RUNTIME_WATCHDOG)], allow_stdout=False),
+    Check('git diff whitespace check', ['git', 'diff', '--check']),
+    Check('git staged diff whitespace check', ['git', 'diff', '--cached', '--check']),
+    Check('npm lint', ['npm', 'run', 'lint']),
+    Check('npm build', ['npm', 'run', 'build']),
+]
+
+
+def run_command(check: Check) -> tuple[bool, str]:
+    env = os.environ.copy()
+    env.setdefault('CI', '1')
+    env.setdefault('PYTHONDONTWRITEBYTECODE', '1')
+    proc = subprocess.run(
+        check.command,
+        cwd=ROOT,
+        text=True,
+        stdout=subprocess.PIPE,
+        stderr=subprocess.STDOUT,
+        env=env,
+        timeout=600,
+    )
+    output = proc.stdout or ''
+    if proc.returncode != 0:
+        return False, f'{check.name} failed rc={proc.returncode}\n{output}'
+    if not check.allow_stdout and output.strip():
+        return False, f'{check.name} expected silent stdout but got:\n{output}'
+    return True, output
+
+
+def secret_scan_diff() -> tuple[bool, str]:
+    proc = subprocess.run(
+        ['git', 'diff', 'HEAD'],
+        cwd=ROOT,
+        text=True,
+        stdout=subprocess.PIPE,
+        stderr=subprocess.STDOUT,
+        timeout=60,
+    )
+    if proc.returncode != 0:
+        return False, f'diff secret scan could not read git diff rc={proc.returncode}\n{proc.stdout}'
+    findings = []
+    for idx, line in enumerate(proc.stdout.splitlines(), start=1):
+        if not line.startswith('+') or line.startswith('+++'):
+            continue
+        if SECRET_RE.search(line):
+            findings.append(f'line {idx}: potential secret in added diff')
+    if findings:
+        return False, 'diff secret scan failed\n' + '\n'.join(findings)
+    return True, 'diff secret scan passed'
+
+
+def print_plan() -> None:
+    for check in CHECKS:
+        print(check.name)
+    print('diff secret scan')
+
+
+def main() -> int:
+    parser = argparse.ArgumentParser(description='Run Mission Control local QA gate')
+    parser.add_argument('--plan', action='store_true', help='print the checks without running them')
+    args = parser.parse_args()
+    if args.plan:
+        print_plan()
+        return 0
+
+    failures: list[str] = []
+    for check in CHECKS:
+        ok, output = run_command(check)
+        if ok:
+            print(f'PASS {check.name}')
+        else:
+            print(f'FAIL {check.name}')
+            failures.append(output)
+    ok, output = secret_scan_diff()
+    if ok:
+        print('PASS diff secret scan')
+    else:
+        print('FAIL diff secret scan')
+        failures.append(output)
+
+    if failures:
+        print('\nMission Control QA gate failed:')
+        for failure in failures:
+            print('\n---')
+            print(failure[-4000:])
+        return 1
+    print('Mission Control QA gate passed')
+    return 0
+
+
+if __name__ == '__main__':
+    raise SystemExit(main())
