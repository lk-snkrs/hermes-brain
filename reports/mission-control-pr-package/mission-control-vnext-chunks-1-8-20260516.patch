+import { opsState } from '@/data/ops-state.generated';
+import type { PermissionLevel } from '@/lib/types';
+
+export type QueueSeverity = 'now' | 'today' | 'watch';
+export type QueueStatus = 'needs-lucas' | 'preview-ready' | 'blocked-external' | 'safe-autonomy';
+export type KanbanLaneId = 'capture' | 'triage' | 'decision' | 'execution' | 'learning' | 'qa' | 'done';
+export type ModuleMaturity = 'live' | 'preview' | 'locked' | 'missing-source';
+
+export interface LucasQueueItem {
+  id: string;
+  domain: string;
+  title: string;
+  why: string;
+  evidence: string;
+  nextGesture: string;
+  blocked: string;
+  gate: PermissionLevel;
+  severity: QueueSeverity;
+  status: QueueStatus;
+}
+
+export interface OperatingKanbanLane {
+  id: KanbanLaneId;
+  title: string;
+  promise: string;
+  items: string[];
+}
+
+export interface ModuleRegistryItem {
+  name: string;
+  purpose: string;
+  source: string;
+  maturity: ModuleMaturity;
+  gate: PermissionLevel;
+}
+
+export interface CooRhythmItem {
+  label: string;
+  detail: string;
+}
+
+function slug(input: string): string {
+  const normalized = input
+    .normalize('NFKD')
+    .replace(/[\u0300-\u036f]/g, '')
+    .toLowerCase()
+    .replace(/[^a-z0-9]+/g, '-')
+    .replace(/^-+|-+$/g, '');
+  return normalized || 'lane';
+}
+
+function gateSeverity(gate: PermissionLevel, index: number): QueueSeverity {
+  if (gate === 'A4') return 'watch';
+  if (gate === 'A3') return 'today';
+  return index === 0 ? 'now' : 'today';
+}
+
+function gateStatus(gate: PermissionLevel): QueueStatus {
+  if (gate === 'A4') return 'blocked-external';
+  if (gate === 'A3') return 'needs-lucas';
+  return 'preview-ready';
+}
+
+function findPacket(packetId: string) {
+  return opsState.actionPackets.find((packet) => packet.packetId === packetId);
+}
+
+export const lucasQueue: LucasQueueItem[] = opsState.waitingLucas.map((item, index) => {
+  const packet = findPacket(item.packetId);
+  return {
+    id: item.packetId,
+    domain: item.company,
+    title: item.decision,
+    why: item.recommendation,
+    evidence: packet?.source || `opsState.waitingLucas · gerado em ${opsState.generatedAt}`,
+    nextGesture: packet?.safeAction || 'Preparar pacote de decisão com fonte, risco e rollback antes de qualquer execução sensível.',
+    blocked: packet?.blockedAction || 'Ações externas, fontes de verdade, dinheiro, cliente, Docker/host e secrets continuam bloqueados sem aprovação atual.',
+    gate: item.gate,
+    severity: gateSeverity(item.gate, index),
+    status: gateStatus(item.gate),
+  };
+});
+
+const kanbanLaneMap: Partial<Record<string, KanbanLaneId>> = {
+  backlog: 'capture',
+  'ready-read-only': 'triage',
+  doing: 'execution',
+  'waiting-lucas': 'decision',
+  'waiting-external': 'decision',
+  qa: 'qa',
+  done: 'done',
+};
+
+export const operatingKanban: OperatingKanbanLane[] = opsState.kanbanPolicy.map((lane) => {
+  const laneSlug = slug(lane.lane);
+  const id = kanbanLaneMap[laneSlug] || 'triage';
+  return {
+    id,
+    title: lane.lane,
+    promise: lane.rule,
+    items: [
+      `dispatch: ${lane.autoDispatch}`,
+      `profiles: ${lane.allowedProfiles}`,
+      lane.autoDispatch === 'never' ? 'segura até Lucas desbloquear' : 'somente read-only/local',
+    ],
+  };
+});
+
+export const moduleRegistry: ModuleRegistryItem[] = [
+  {
+    name: 'Lucas Queue',
+    purpose: `${opsState.waitingLucas.length} decisões derivadas de opsState.waitingLucas e actionPackets.`,
+    source: `ops-state.generated.ts · ${opsState.generatedAt}`,
+    maturity: 'live',
+    gate: 'A2',
+  },
+  {
+    name: 'Action Packets',
+    purpose: `${opsState.actionPackets.length} pacotes com hash, expiração, safeAction e blockedAction.`,
+    source: '/api/mission/packets + approval receipt backend',
+    maturity: 'live',
+    gate: 'A3',
+  },
+  {
+    name: 'Kanban restrito',
+    purpose: `${opsState.kanbanPolicy.length} lanes com política de dispatch; browser nunca executa workers.`,
+    source: '/api/mission/kanban + lk-growth-ops policy',
+    maturity: 'live',
+    gate: 'A3',
+  },
+  {
+    name: 'Health Center',
+    purpose: `${opsState.healthCenter.length} sinais de saúde sanitizados para status executivo.`,
+    source: '/api/mission/state publicState() no-store/noindex',
+    maturity: 'live',
+    gate: 'A1',
+  },
+  {
+    name: 'Command Palette',
+    purpose: 'Botões geram recibos e contratos; não shell arbitrário nem write externo.',
+    source: '/api/mission/approvals + /execute allowlist',
+    maturity: 'preview',
+    gate: 'A4',
+  },
+  {
+    name: 'Feed Quality',
+    purpose: `${opsState.feedQuality.packetCount} packets únicos; ${opsState.feedQuality.waitingPacketCoverage}/${opsState.feedQuality.waitingLucasCount} decisões cobertas; status ${opsState.feedQuality.status}.`,
+    source: 'scripts/mission_control_ops_state.py validate_state() + feedQuality',
+    maturity: 'live',
+    gate: 'A1',
+  },
+  {
+    name: 'Cost & Sessions',
+    purpose: 'Só deve sair de placeholder quando houver fonte real de runtime/sessão/custo.',
+    source: 'runtime/session logs pendentes',
+    maturity: 'missing-source',
+    gate: 'A2',
+  },
+];
+
+export const cooRhythm: CooRhythmItem[] = [
+  { label: 'Manhã', detail: `Ver ${opsState.waitingLucas.length} itens da Lucas Queue: decisão, gate, expiração e fonte.` },
+  { label: 'Durante o dia', detail: 'Deixar Hermes executar A0-A2 local/read-only; exigir pacote para A3/A4.' },
+  { label: 'Fim do dia', detail: 'Revisar receipts, ruído, pendências expiradas e aprendizados que viram Brain/skill.' },
+];
