+import datetime as dt
+import importlib.util
+import json
+import tempfile
+import unittest
+from pathlib import Path
+
+ROOT = Path(__file__).resolve().parents[1]
+WATCHDOG_PATH = ROOT / 'scripts' / 'mission_control_ops_watchdog.py'
+
+
+def load_watchdog():
+    spec = importlib.util.spec_from_file_location('mission_control_ops_watchdog', WATCHDOG_PATH)
+    if spec is None or spec.loader is None:
+        raise RuntimeError(f'Could not load watchdog module from {WATCHDOG_PATH}')
+    module = importlib.util.module_from_spec(spec)
+    spec.loader.exec_module(module)
+    return module
+
+
+def base_ops_state() -> dict:
+    now = dt.datetime.now(dt.UTC).replace(microsecond=0)
+    expires = (now + dt.timedelta(hours=6)).isoformat().replace('+00:00', 'Z')
+    return {
+        'generatedAt': now.isoformat().replace('+00:00', 'Z'),
+        'freshnessSlaHours': 24,
+        'health': [{'label': 'ok'}],
+        'healthCenter': [{'system': 'Feed Quality', 'status': 'green', 'signal': 'ok'}],
+        'commandSystem': [{'name': 'ok'}],
+        'improvements12': [{'id': f'p{i:02d}'} for i in range(12)],
+        'approvalLedger': [{'gate': 'A1'}],
+        'actionPackets': [
+            {'packetId': 'packet-a', 'expiresAt': expires},
+            {'packetId': 'packet-b', 'expiresAt': expires},
+        ],
+        'waitingLucas': [{'packetId': 'packet-a'}],
+        'eventLedger': [{'eventId': 'e1'}],
+        'kanbanPolicy': [{'lane': 'Ready Read-only'}],
+        'rollbackRegistry': [{'component': 'Mission Control'}],
+        'lkOperatingIntelligence': [{'signal': 'read-only'}],
+        'watchers': [
+            {'id': 'feec299b99e5'},
+            {'id': '4bb4e2223fd3'},
+            {'id': 'edd06fe19397'},
+        ],
+        'artifacts': [{'path': 'src/data/ops-state.generated.ts'}],
+        'feedQuality': {
+            'status': 'green',
+            'waitingPacketCoverage': 1,
+            'waitingLucasCount': 1,
+            'missingWaitingPackets': [],
+            'duplicatePacketIdsRemoved': [],
+            'expiredPackets': [],
+            'staleEvidence': [],
+        },
+    }
+
+
+def write_state(directory: Path, state: dict) -> Path:
+    path = directory / 'mission-control-ops-state-latest.json'
+    path.write_text(json.dumps(state, ensure_ascii=False))
+    return path
+
+
+class MissionControlOpsWatchdogTests(unittest.TestCase):
+    def setUp(self):
+        self.watchdog = load_watchdog()
+        self.tmpdir = tempfile.TemporaryDirectory()
+        self.tmp_path = Path(self.tmpdir.name)
+
+    def tearDown(self):
+        self.tmpdir.cleanup()
+
+    def test_validate_ops_state_file_is_silent_for_green_feed(self):
+        alerts: list[str] = []
+
+        self.watchdog.validate_ops_state_file(write_state(self.tmp_path, base_ops_state()), alerts)
+
+        self.assertEqual(alerts, [])
+
+    def test_validate_ops_state_file_alerts_when_feed_quality_is_yellow(self):
+        state = base_ops_state()
+        state['feedQuality']['status'] = 'yellow'
+        state['feedQuality']['missingWaitingPackets'] = ['missing-packet']
+        alerts: list[str] = []
+
+        self.watchdog.validate_ops_state_file(write_state(self.tmp_path, state), alerts)
+
+        self.assertIn('Mission Control feedQuality not green: yellow', alerts)
+        self.assertIn("Mission Control feedQuality missingWaitingPackets: ['missing-packet']", alerts)
+
+    def test_validate_ops_state_file_alerts_when_health_center_lacks_feed_quality(self):
+        state = base_ops_state()
+        state['healthCenter'] = [{'system': 'Mission Control', 'status': 'green'}]
+        alerts: list[str] = []
+
+        self.watchdog.validate_ops_state_file(write_state(self.tmp_path, state), alerts)
+
+        self.assertIn('Mission Control Health Center missing Feed Quality signal', alerts)
+
+
+if __name__ == '__main__':
+    unittest.main()
