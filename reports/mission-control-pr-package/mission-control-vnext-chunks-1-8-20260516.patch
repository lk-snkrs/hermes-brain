+#!/usr/bin/env python3
+"""Mission Control operational watchdog.
+
+Silent contract: rc=0 + empty stdout = healthy; rc=0 + stdout = actionable alert.
+Allowed low-risk self-heal: regenerate the local Mission Control ops-state JSON/TS feed
+when stale/missing. No external sends, Shopify/Tiny/Merchant writes, Docker/host/Vercel
+mutation, gateway restart, or secret printing.
+"""
+from __future__ import annotations
+
+import datetime as dt
+import hashlib
+import json
+import subprocess
+from pathlib import Path
+from urllib.error import HTTPError, URLError
+from urllib.request import Request, urlopen
+
+ROOT = Path('/opt/data/hermes_bruno_ingest/mission-control-cimino-hermes')
+BRAIN = Path('/opt/data/hermes_bruno_ingest/hermes-brain')
+URL = 'https://mission.lucascimino.com/?watchdog=mission-control'
+OPS_JSON = BRAIN / 'reports/mission-control-ops-state-latest.json'
+OPS_TS = ROOT / 'src/data/ops-state.generated.ts'
+GENERATOR = Path('/opt/data/scripts/mission_control_ops_state.py')
+REQUIRED_FILES = [
+    ROOT / 'src/components/modules/MissionPages.tsx',
+    ROOT / 'src/components/modules/CommandActionPanel.tsx',
+    ROOT / 'src/app/api/mission/state/route.ts',
+    ROOT / 'src/app/api/mission/approvals/route.ts',
+    ROOT / 'src/app/api/mission/kanban/route.ts',
+    ROOT / 'src/app/api/mission/packets/route.ts',
+    ROOT / 'src/app/api/mission/execute/route.ts',
+    ROOT / 'src/data/cron-jobs.ts',
+    ROOT / 'src/data/ops-state.generated.ts',
+    ROOT / 'scripts/mission_control_ops_state.py',
+    BRAIN / 'reports/mission-control-ops-state-latest.json',
+    BRAIN / 'skills/lk-shopify-readonly/SKILL.md',
+    BRAIN / 'skills/lk-shopify-product-upload/SKILL.md',
+    Path('/opt/data/scripts/hermes_compression_failure_self_heal.py'),
+]
+REQUIRED_DEPLOYED_MARKERS = [
+    'Mission Control',
+    'LK Sneakers',
+]
+REQUIRED_LOCAL_MARKERS = [
+    'CommandActionPanel',
+    'moduleRegistry',
+    'lucasQueue',
+    'operatingKanban',
+]
+REQUIRED_OPS_LISTS = [
+    'health',
+    'healthCenter',
+    'commandSystem',
+    'improvements12',
+    'approvalLedger',
+    'waitingLucas',
+    'actionPackets',
+    'eventLedger',
+    'kanbanPolicy',
+    'rollbackRegistry',
+    'lkOperatingIntelligence',
+    'watchers',
+    'artifacts',
+]
+
+
+def sha(path: Path) -> str:
+    return hashlib.sha256(path.read_bytes()).hexdigest()
+
+
+def utc_now() -> dt.datetime:
+    return dt.datetime.now(dt.UTC)
+
+
+def parse_ts(ts: str) -> dt.datetime | None:
+    try:
+        text = ts.replace('Z', '+00:00')
+        return dt.datetime.fromisoformat(text)
+    except Exception:
+        return None
+
+
+def regenerate_if_needed(alerts: list[str]) -> None:
+    needs = False
+    if not OPS_JSON.exists() or not OPS_TS.exists():
+        needs = True
+    elif GENERATOR.exists():
+        try:
+            data = json.loads(OPS_JSON.read_text())
+            generated = parse_ts(str(data.get('generatedAt', '')))
+            if generated is None or (utc_now() - generated).total_seconds() > 24 * 3600:
+                needs = True
+        except Exception:
+            needs = True
+    if needs:
+        if not GENERATOR.exists():
+            alerts.append(f'Mission Control ops-state generator missing: {GENERATOR}')
+            return
+        proc = subprocess.run([str(GENERATOR)], text=True, stdout=subprocess.PIPE, stderr=subprocess.STDOUT, timeout=60)
+        if proc.returncode != 0:
+            alerts.append(f'ops-state regeneration failed rc={proc.returncode}: {proc.stdout[-500:]}')
+
+
+def validate_ops_state(alerts: list[str]) -> None:
+    validate_ops_state_file(OPS_JSON, alerts)
+
+
+def validate_ops_state_file(path: Path, alerts: list[str]) -> None:
+    if not path.exists():
+        alerts.append(f'Mission Control ops-state JSON missing: {path}')
+        return
+    try:
+        data = json.loads(path.read_text())
+    except Exception as exc:
+        alerts.append(f'Mission Control ops-state JSON invalid: {type(exc).__name__}: {str(exc)[:120]}')
+        return
+    generated = parse_ts(str(data.get('generatedAt', '')))
+    if generated is None:
+        alerts.append('Mission Control ops-state generatedAt invalid/missing')
+    else:
+        age_hours = (utc_now() - generated).total_seconds() / 3600
+        if age_hours > float(data.get('freshnessSlaHours', 24)):
+            alerts.append(f'Mission Control ops-state stale: {age_hours:.1f}h old')
+    for key in REQUIRED_OPS_LISTS:
+        if not isinstance(data.get(key), list) or not data[key]:
+            alerts.append(f'Mission Control ops-state missing non-empty {key}')
+    if len(data.get('improvements12', [])) != 12:
+        alerts.append(f"Mission Control ops-state improvements12 count is {len(data.get('improvements12', []))}, expected 12")
+
+    packet_ids = [item.get('packetId') for item in data.get('actionPackets', []) if isinstance(item, dict)]
+    duplicate_packet_ids = sorted({item for item in packet_ids if packet_ids.count(item) > 1})
+    if duplicate_packet_ids:
+        alerts.append(f'Mission Control duplicate action packet ids: {duplicate_packet_ids}')
+    waiting_ids = [item.get('packetId') for item in data.get('waitingLucas', []) if isinstance(item, dict)]
+    missing_waiting_packets = sorted(str(item) for item in waiting_ids if item not in set(packet_ids))
+    if missing_waiting_packets:
+        alerts.append(f'Mission Control Waiting Lucas packet coverage broken: missing {missing_waiting_packets}')
+
+    feed_quality = data.get('feedQuality')
+    if not isinstance(feed_quality, dict):
+        alerts.append('Mission Control feedQuality missing or invalid')
+    else:
+        if feed_quality.get('status') != 'green':
+            alerts.append(f"Mission Control feedQuality not green: {feed_quality.get('status')}")
+        if feed_quality.get('missingWaitingPackets'):
+            alerts.append(f"Mission Control feedQuality missingWaitingPackets: {feed_quality.get('missingWaitingPackets')}")
+        if feed_quality.get('duplicatePacketIdsRemoved'):
+            alerts.append(f"Mission Control feedQuality removed duplicate packet ids: {feed_quality.get('duplicatePacketIdsRemoved')}")
+        if feed_quality.get('expiredPackets'):
+            alerts.append(f"Mission Control feedQuality expired packets: {feed_quality.get('expiredPackets')}")
+        if int(feed_quality.get('waitingPacketCoverage') or 0) != len(data.get('waitingLucas', [])):
+            alerts.append(
+                f"Mission Control feedQuality coverage mismatch: {feed_quality.get('waitingPacketCoverage')}/{len(data.get('waitingLucas', []))}"
+            )
+        stale = feed_quality.get('staleEvidence')
+        if stale:
+            alerts.append(f'Mission Control feedQuality stale evidence: {json.dumps(stale, ensure_ascii=False)[:400]}')
+
+    health_systems = {item.get('system') for item in data.get('healthCenter', []) if isinstance(item, dict)}
+    if 'Feed Quality' not in health_systems:
+        alerts.append('Mission Control Health Center missing Feed Quality signal')
+
+    watcher_ids = {item.get('id') for item in data.get('watchers', []) if isinstance(item, dict)}
+    for required in ['feec299b99e5', '4bb4e2223fd3', 'edd06fe19397']:
+        if required not in watcher_ids:
+            alerts.append(f'Mission Control ops-state missing watcher id {required}')
+
+
+def main() -> int:
+    alerts: list[str] = []
+    regenerate_if_needed(alerts)
+
+    for path in REQUIRED_FILES:
+        if not path.exists():
+            alerts.append(f'missing required Mission Control artifact: {path}')
+        elif path.stat().st_size < 200:
+            alerts.append(f'suspiciously small artifact: {path} ({path.stat().st_size} bytes)')
+
+    validate_ops_state(alerts)
+
+    for name in ['lk-shopify-readonly', 'lk-shopify-product-upload']:
+        rt = Path(f'/opt/data/skills/productivity/{name}/SKILL.md')
+        br = BRAIN / f'skills/{name}/SKILL.md'
+        if rt.exists() and br.exists() and sha(rt) != sha(br):
+            alerts.append(f'{name} skill drift: runtime and Brain mirror differ')
+
+    local_text = (ROOT / 'src/components/modules/MissionPages.tsx').read_text(errors='replace') if (ROOT / 'src/components/modules/MissionPages.tsx').exists() else ''
+    for marker in REQUIRED_LOCAL_MARKERS:
+        if marker not in local_text:
+            alerts.append(f'Mission Control local UI marker missing: {marker}')
+
+    try:
+        req = Request(URL, headers={'User-Agent': 'HermesMissionControlWatchdog/1.1'})
+        with urlopen(req, timeout=12) as resp:
+            status = getattr(resp, 'status', None)
+            body = resp.read(250000).decode('utf-8', errors='replace')
+        if status != 200:
+            alerts.append(f'Mission Control HTTP status is {status}, expected 200')
+        for marker in REQUIRED_DEPLOYED_MARKERS:
+            if marker not in body:
+                alerts.append(f'Mission Control marker not found in HTML: {marker}')
+    except (HTTPError, URLError, TimeoutError, OSError) as exc:
+        alerts.append(f'Mission Control public GET failed: {type(exc).__name__}: {str(exc)[:180]}')
+
+    if alerts:
+        print('Mission Control ops watchdog alert')
+        for item in alerts:
+            print(f'- {item}')
+    return 0
+
+
+if __name__ == '__main__':
+    raise SystemExit(main())
