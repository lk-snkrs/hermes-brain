+import { createHash } from 'node:crypto';
+import { opsState } from '@/data/ops-state.generated';
+
+export type MissionAction = 'approve_scope' | 'adjust' | 'preview_only' | 'block' | 'kanban_dispatch_packet' | 'execute_safe';
+
+const ACTION_LABELS: Record<MissionAction, string> = {
+  approve_scope: 'Aprovar escopo',
+  adjust: 'Ajustar',
+  preview_only: 'Preview only',
+  block: 'Bloquear',
+  kanban_dispatch_packet: 'Gerar pacote Kanban',
+  execute_safe: 'Execution Bridge A1/A2',
+};
+
+const KANBAN_PROFILES = ['hermes-ops-readonly', 'brain-process', 'lk-analyst-readonly', 'lk-content-reviewer'] as const;
+const RATE_BUCKET = new Map<string, { count: number; resetAt: number }>();
+const RATE_WINDOW_MS = 60_000;
+const RATE_LIMIT = 30;
+
+export function slugify(input: string) {
+  return input
+    .normalize('NFKD')
+    .replace(/[\u0300-\u036f]/g, '')
+    .toLowerCase()
+    .replace(/[^a-z0-9]+/g, '-')
+    .replace(/^-+|-+$/g, '')
+    .slice(0, 96);
+}
+
+export function publicHeaders(extra?: Record<string, string>) {
+  return {
+    'cache-control': 'no-store, max-age=0',
+    'content-type': 'application/json; charset=utf-8',
+    'x-mission-control': 'lucas-command-system',
+    'x-robots-tag': 'noindex',
+    ...extra,
+  };
+}
+
+export function sanitizeText(value: unknown, max = 600) {
+  const text = typeof value === 'string' ? value : '';
+  return text
+    .replace(/(sk-|ghp_|gho_|xox[baprs]-|AIza|ya29\.|-----BEGIN [A-Z ]+PRIVATE KEY-----)[A-Za-z0-9_./+=:-]*/g, '[REDACTED]')
+    .replace(/[A-Za-z0-9._%+-]+@[A-Za-z0-9.-]+\.[A-Za-z]{2,}/g, '[email-redacted]')
+    .replace(/\b(?:\d[ -]*?){13,19}\b/g, '[number-redacted]')
+    .replace(/\s+/g, ' ')
+    .trim()
+    .slice(0, max);
+}
+
+export function parseAction(value: unknown): MissionAction | null {
+  if (value === 'approve_scope' || value === 'adjust' || value === 'preview_only' || value === 'block' || value === 'kanban_dispatch_packet' || value === 'execute_safe') return value;
+  return null;
+}
+
+export function actionPackets() {
+  return opsState.actionPackets.map((packet) => ({
+    ...packet,
+    packetId: slugify(packet.packetId),
+  }));
+}
+
+export function allowedPacketIds() {
+  return new Set([
+    ...opsState.waitingLucas.map((item) => slugify(String((item as { packetId?: string }).packetId || 'waiting-lucas'))),
+    ...actionPackets().map((packet) => packet.packetId),
+    'mission-control-p2-backend-api-kanban',
+    'lk-growth-ops-dispatch-pilot',
+    'mission-control-vnext-operating-loops',
+    'mission-control-safe-execution-bridge',
+  ]);
+}
+
+export function findPacket(packetId: string) {
+  const id = slugify(packetId || 'mission-control-reliability-layer');
+  return actionPackets().find((packet) => packet.packetId === id) || null;
+}
+
+export function checkRateLimit(key: string) {
+  const now = Date.now();
+  const bucket = RATE_BUCKET.get(key);
+  if (!bucket || bucket.resetAt < now) {
+    RATE_BUCKET.set(key, { count: 1, resetAt: now + RATE_WINDOW_MS });
+    return { ok: true, remaining: RATE_LIMIT - 1, resetAt: now + RATE_WINDOW_MS };
+  }
+  if (bucket.count >= RATE_LIMIT) return { ok: false, remaining: 0, resetAt: bucket.resetAt };
+  bucket.count += 1;
+  return { ok: true, remaining: RATE_LIMIT - bucket.count, resetAt: bucket.resetAt };
+}
+
+export async function verifyOptionalToken(authHeader: string | null) {
+  const expectedHash = process.env.MISSION_CONTROL_APPROVAL_TOKEN_HASH;
+  if (!expectedHash) return { ok: true, mode: 'optional-not-configured' };
+  const token = authHeader?.replace(/^Bearer\s+/i, '').trim() || '';
+  const actual = createHash('sha256').update(token).digest('hex');
+  return { ok: actual === expectedHash, mode: 'sha256-bearer' };
+}
+
+function packetExpiry(packet: ReturnType<typeof findPacket>) {
+  if (!packet?.expiresAt) return { expired: false, expiresAt: null as string | null };
+  return { expired: Date.parse(packet.expiresAt) < Date.now(), expiresAt: packet.expiresAt };
+}
+
+export function makeApprovalReceipt(input: {
+  packetId: string;
+  action: MissionAction;
+  note?: string;
+  source?: string;
+  clientKey?: string;
+}) {
+  const packetId = slugify(input.packetId || 'mission-control-reliability-layer');
+  const action = input.action;
+  if (!allowedPacketIds().has(packetId)) {
+    throw new Error('packet_id_not_allowlisted');
+  }
+  const packet = findPacket(packetId);
+  const expiry = packetExpiry(packet);
+  if (expiry.expired) {
+    throw new Error('packet_expired');
+  }
+  const note = sanitizeText(input.note || '', 420);
+  const receivedAt = new Date().toISOString();
+  const gate = packet?.gate || (action === 'approve_scope' || action === 'kanban_dispatch_packet' ? 'A3' : 'A2');
+  const scope = {
+    gate,
+    execution: action === 'execute_safe' ? 'a1-a2-local-contract-only' : action === 'approve_scope' ? 'accepted-for-human-reviewed-ops-queue' : 'no-mutating-execution',
+    externalSend: false,
+    secrets: false,
+    expiresAt: expiry.expiresAt,
+    payloadHash: packet?.payloadHash || createHash('sha256').update(packetId).digest('hex').slice(0, 16),
+    rollback: packet?.rollback || 'disable API routes and redeploy previous Vercel build; no external data was mutated by this receipt endpoint',
+  };
+  const receiptBase = JSON.stringify({ packetId, action, note, receivedAt, scope, packetStatus: packet?.status });
+  const receiptId = createHash('sha256').update(receiptBase).digest('hex').slice(0, 16);
+  return {
+    ok: true,
+    receiptId,
+    packetId,
+    action,
+    label: ACTION_LABELS[action],
+    note,
+    receivedAt,
+    source: sanitizeText(input.source || 'mission-control-ui', 120),
+    packet: packet ? {
+      company: packet.company,
+      decision: packet.decision,
+      status: packet.status,
+      confidence: packet.confidence,
+      safeAction: packet.safeAction,
+      blockedAction: packet.blockedAction,
+    } : null,
+    scope,
+    nextStep: action === 'execute_safe'
+      ? 'Bridge restrito: apenas contrato/artefato local A1/A2; nenhuma ação externa ou fonte de verdade foi modificada por este endpoint.'
+      : action === 'approve_scope'
+      ? 'Escopo aprovado por Lucas; execução operacional ainda passa pelos guardrails do pacote, expiração e logs locais.'
+      : 'Nenhuma mutação executada; o retorno serve como trilha de decisão e instrução de próximo passo.',
+  };
+}
+
+export function publicState() {
+  return {
+    ...opsState,
+    generatedFrom: 'sanitized-local-feed',
+    secretsIncluded: false,
+  };
+}
+
+export function kanbanCapabilities() {
+  return {
+    ok: true,
+    board: 'lk-growth-ops',
+    mode: 'restricted-workers',
+    publicEndpointExecutesWorkers: false,
+    profiles: KANBAN_PROFILES.map((profile) => ({
+      profile,
+      permission: profile.includes('readonly') ? 'read-only/local' : 'local-brain-only',
+      allowedActions: ['read Brain context', 'summarize', 'draft local report', 'block for Lucas when A3/A4 is needed'],
+      deniedActions: ['external send', 'Shopify/Tiny/Merchant write', 'Docker/host mutation', 'secret print', 'destructive command'],
+    })),
+    lanes: opsState.kanbanPolicy,
+    dispatchContract: 'Gateway/local Hermes dispatcher only; public API creates/validates packets and never spawns arbitrary code from the browser.',
+    rollback: 'unassign ready worker cards or disable dispatch cron/gateway integration; API route can be removed and previous Vercel deploy promoted.',
+  };
+}
