+def read_ledger(limit: int = 8) -> list[dict]:
+    if not LEDGER.exists():
+        return []
+    rows = []
+    for line in LEDGER.read_text(errors='replace').splitlines():
+        if not line.strip():
+            continue
+        try:
+            item = json.loads(line)
+            # keep only sanitized public fields
+            rows.append({k: item.get(k) for k in ['eventId','ts','source','packetId','action','gate','status','scopeHash','summary','rollback']})
+        except Exception:
+            continue
+    return rows[-limit:][::-1]
