+    changed = [line for line in status.splitlines() if line.strip()]
+    return {
+        'branch': branch.strip() if rc_branch == 0 else 'unknown',
+        'remote': remote.strip().replace('https://github.com/', 'github:') if rc_remote == 0 else 'unknown',
