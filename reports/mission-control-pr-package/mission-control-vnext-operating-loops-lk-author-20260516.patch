+import { NextRequest } from 'next/server';
+import { checkRateLimit, makeApprovalReceipt, parseAction, publicHeaders, sanitizeText, verifyOptionalToken } from '@/lib/mission-control-api';
+
+export const dynamic = 'force-dynamic';
+
+export async function GET() {
+  return Response.json({
+    ok: true,
+    endpoint: '/api/mission/execute',
+    mode: 'a1-a2-local-contract-only',
+    allowedEffects: ['mark_packet_resolved', 'generate_report', 'create_readonly_kanban_card', 'create_local_draft', 'run_allowlisted_readonly_script_preview'],
+    deniedEffects: ['external_send', 'shopify_tiny_merchant_write', 'campaign_edit', 'purchase_supplier_contact', 'docker_host_gateway_mutation', 'secret_access', 'arbitrary_shell'],
+    publicEndpointExecutesCommands: false,
+  }, { headers: publicHeaders() });
+}
+
+export async function POST(request: NextRequest) {
+  const clientKey = request.headers.get('x-forwarded-for') || request.headers.get('x-real-ip') || 'anonymous';
+  const rate = checkRateLimit(`execute:${clientKey}`);
+  if (!rate.ok) {
+    return Response.json({ ok: false, error: 'rate_limited', resetAt: rate.resetAt }, { status: 429, headers: publicHeaders() });
+  }
+  const auth = await verifyOptionalToken(request.headers.get('authorization'));
+  if (!auth.ok) {
+    return Response.json({ ok: false, error: 'unauthorized', authMode: auth.mode }, { status: 401, headers: publicHeaders() });
+  }
+  let body: Record<string, unknown> = {};
+  try { body = await request.json(); } catch { body = {}; }
+  const action = parseAction(body.action || 'execute_safe');
+  if (action !== 'execute_safe') {
+    return Response.json({ ok: false, error: 'execute_endpoint_requires_execute_safe' }, { status: 400, headers: publicHeaders() });
+  }
+  const requestedEffect = sanitizeText(body.effect || 'generate_report', 80);
+  const allowed = ['mark_packet_resolved', 'generate_report', 'create_readonly_kanban_card', 'create_local_draft', 'run_allowlisted_readonly_script_preview'];
+  if (!allowed.includes(requestedEffect)) {
+    return Response.json({ ok: false, error: 'effect_not_allowlisted', allowed }, { status: 400, headers: publicHeaders() });
+  }
+  try {
+    const receipt = makeApprovalReceipt({
+      packetId: String(body.packetId || 'mission-control-safe-execution-bridge'),
+      action,
+      note: `${requestedEffect}: ${sanitizeText(body.note || '', 320)}`,
+      source: body.source ? String(body.source) : 'mission-control-execute-api',
+      clientKey,
+    });
+    return Response.json({
+      ...receipt,
+      effect: requestedEffect,
+      executed: false,
+      executionBridge: 'contract-only-public-api; actual local artifact writes remain server-side allowlisted scripts, not browser commands',
+      authMode: auth.mode,
+      rateLimitRemaining: rate.remaining,
+    }, { headers: publicHeaders() });
+  } catch (error) {
+    return Response.json({ ok: false, error: error instanceof Error ? error.message : 'receipt_failed' }, { status: 400, headers: publicHeaders() });
+  }
+}
