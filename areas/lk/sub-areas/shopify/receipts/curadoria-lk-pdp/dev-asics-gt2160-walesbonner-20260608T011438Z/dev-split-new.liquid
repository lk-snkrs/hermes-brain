{%- assign lk_titles = "Tênis Asics GT-2160 x Above the Clouds White Pure Silver Branco | Tênis Asics GT-2160 White Putty Branco | Tênis Asics GT-2160 x Kith Marvel Villains Spider-Man/Venom Colorido | Tênis Asics GT-2160 x Gallery Dept. ComplexCon Cinza | Tênis Asics GT-2160 x PaperGirl Beams White Silver Branco | Tênis Asics GT-2160 x JJJJound White Branco" | split: " | " -%}
{%- assign lk_rendered_count = 0 -%}
{%- assign lk_has_current = false -%}
{%- for lk_handle in lk_handles -%}
  {%- if lk_handle == product.handle -%}{%- assign lk_has_current = true -%}{%- endif -%}
{%- endfor -%}
{%- if lk_has_current -%}
  <section class="lk-variante" data-lk-variante="top30-asics-gt-2160-regular" aria-label="Curadoria LK ASICS GT-2160">
    <div class="lk-variante__head"><span class="lk-variante__eyebrow">Curadoria LK</span><span class="lk-variante__title">Outras variações</span></div>
    <div class="lk-variante__rail" role="list">
      {%- for lk_handle in lk_handles -%}
        {%- if lk_handle != product.handle and lk_rendered_count < 5 -%}
          {%- assign lk_index = forloop.index0 -%}
          {%- assign lk_label = lk_labels[lk_index] -%}
          {%- assign lk_image = lk_images[lk_index] -%}
          {%- assign lk_title = lk_titles[lk_index] -%}
          <a class="lk-variante__item" href="/products/{{ lk_handle }}" role="listitem" title="{{ lk_title | escape }}">
            <span class="lk-variante__media"><img src="{{ lk_image }}" alt="{{ lk_title | escape }}" width="72" height="72" loading="lazy" decoding="async"></span>
            <span class="lk-variante__label">{{ lk_label }}</span>
          </a>
          {%- assign lk_rendered_count = lk_rendered_count | plus: 1 -%}
        {%- endif -%}
      {%- endfor -%}
    </div>
  </section>
{%- endif -%}

